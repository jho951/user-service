USER_SERVICE_IMAGE=123456789012.dkr.ecr.ap-northeast-2.amazonaws.com/prod-user-service:latest
SERVICE_SHARED_NETWORK=service-backbone-shared
TZ=Asia/Seoul
USER_SERVICE_HOST_BIND=127.0.0.1
USER_SERVICE_HOST_PORT=8082
SPRING_PROFILES_ACTIVE=prod
MYSQL_DATABASE=user_service
MYSQL_USER=user_service
MYSQL_PASSWORD=change-me
MYSQL_ROOT_PASSWORD=change-root-me
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/user_service?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=user_service
SPRING_DATASOURCE_PASSWORD=change-me
USER_SERVICE_INTERNAL_JWT_ISSUER=api-gateway
USER_SERVICE_INTERNAL_JWT_AUDIENCE=internal-services
USER_SERVICE_INTERNAL_JWT_SECRET=at-least-32-byte-secret
AUTH_JWT_SECRET=at-least-32-byte-secret
FEATURES_PUBLIC_USER_API_ENABLED=true
FEATURES_INTERNAL_USER_API_ENABLED=true
FEATURES_ADMIN_API_ENABLED=false
FEATURES_ADMIN_AUTH_ENABLED=false
